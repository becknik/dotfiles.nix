index 0000000..f7a10e8
--- /dev/null
+++ b/lua/Arduino-Nvim/telescopeCustomizations.lua
@@ -0,0 +1,10 @@
+local M = {}
+
+function M.new_picker(opts, defaults)
+	opts = opts or {}
+	opts = require("telescope.themes").get_ivy(opts)
+
+	return require("telescope.pickers").new(opts, defaults)
+end
+
+return M
