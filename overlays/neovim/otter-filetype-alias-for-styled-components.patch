diff --git a/lua/otter/lsp/init.lua b/lua/otter/lsp/init.lua
index 96d58b4..d103a27 100644
--- a/lua/otter/lsp/init.lua
+++ b/lua/otter/lsp/init.lua
@@ -16,10 +16,62 @@ end
 ---@field main_uri string?
 ---@field otter_uri string?
 
 local otterls = {}
 
+---Merge two LSP results returned by different language servers attached to the
+---same otter buffer. Completion lists are merged item-by-item (preserving the
+---isIncomplete flag so clients keep fetching). All other methods return a list
+---of locations/symbols/edits, so their results are concatenated. A non-list
+---result (e.g. a single Hover object) wins over a list and is kept as-is; if
+---both are non-list, the first one is kept.
+---@param method string lsp method
+---@param a table first result
+---@param b table second result
+---@return table merged
+local function merge_results(method, a, b)
+  if method == ms.textDocument_completion then
+    -- Normalize both into { isIncomplete = bool, items = [...] }
+    local function normalize(res)
+      if res.isIncomplete ~= nil then
+        return { isIncomplete = res.isIncomplete == true, items = res.items or {} }
+      elseif type(res) == "table" then
+        return { isIncomplete = false, items = res }
+      end
+      return { isIncomplete = false, items = {} }
+    end
+    local na = normalize(a)
+    local nb = normalize(b)
+    local items = {}
+    for _, item in ipairs(na.items) do
+      table.insert(items, item)
+    end
+    for _, item in ipairs(nb.items) do
+      table.insert(items, item)
+    end
+    return { isIncomplete = na.isIncomplete or nb.isIncomplete, items = items }
+  end
+
+  -- For list-returning methods (definition, references, documentSymbol, ...)
+  -- concatenate the results. If either side is not a list, keep the first
+  -- non-list result (e.g. Hover, or a single Location).
+  local function is_list(t)
+    return type(t) == "table" and (vim.islist(t) or t[1] ~= nil)
+  end
+  if is_list(a) and is_list(b) then
+    local merged = {}
+    for _, v in ipairs(a) do
+      table.insert(merged, v)
+    end
+    for _, v in ipairs(b) do
+      table.insert(merged, v)
+    end
+    return merged
+  end
+  return a
+end
+
 --- @param main_nr integer main buffer
 --- @param completion boolean should completion be enabled?
 --- @return integer? client_id
 otterls.start = function(main_nr, completion)
   local main_uri = vim.uri_from_bufnr(main_nr)
@@ -167,14 +219,54 @@ otterls.start = function(main_nr, completion)
               includeDeclaration = true,
             }
           end
           -- take care of potential indents
           keeper.modify_position(params, main_nr, true, true)
-          -- send the request to the otter buffer
+          -- send the request to the otter buffer and aggregate the responses
+          -- from all language servers attached to it before replying.
+          --
+          -- We must use buf_request_all (single aggregated callback) instead of
+          -- buf_request (per-client callback). Several language servers can be
+          -- attached to the same otter buffer (e.g. a css otter buffer may be
+          -- backed by cssls, tailwindcss and css_variables at once). With
+          -- buf_request the handler -- and therefore the client that issued the
+          -- request (e.g. blink.cmp) -- would be invoked once per responding
+          -- server. Completion clients resolve their async task on the first
+          -- invocation, so a fast server returning an empty list would win over
+          -- a slower server (e.g. cssls) that actually has the completions,
+          -- yielding no autocompletion at all. Aggregating all responses and
+          -- replying a single time fixes this.
+          --
           -- modification of the response is done by our handler
           -- and then passed on to the default handler or user-defined handler
-          vim.lsp.buf_request(otter_nr, method, params, function(err, result, ctx)
+          vim.lsp.buf_request_all(otter_nr, method, params, function(responses)
+            -- responses is a table mapping client_id -> { err, result }
+            local merged_result = nil
+            local first_client_id = nil
+            for client_id, res in pairs(responses) do
+              if first_client_id == nil then
+                first_client_id = client_id
+              end
+              if res and res.result ~= nil then
+                if merged_result == nil then
+                  merged_result = res.result
+                else
+                  merged_result = merge_results(method, merged_result, res.result)
+                end
+              end
+            end
+
+            -- synthesize a handler context from the request params.
+            -- handlers rely on ctx.params.otter.* and ctx.params.textDocument
+            local ctx = {
+              params = params,
+              bufnr = otter_nr,
+              client_id = first_client_id,
+            }
+
+            local err = nil
+            local result = merged_result
             if handlers[method] ~= nil then
               err, result, ctx = handlers[method](err, result, ctx)
             end
             handler(err, result, ctx)
           end)
