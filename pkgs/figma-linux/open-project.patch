diff --git a/src/utils/Common/displayServer.ts b/src/utils/Common/displayServer.ts
new file mode 100644
index 0000000..e506d77
--- /dev/null
+++ b/src/utils/Common/displayServer.ts
@@ -0,0 +1,19 @@
+/**
+ * Detects if the application is running on Wayland
+ */
+export function isWayland(): boolean {
+  const sessionType = process.env.XDG_SESSION_TYPE;
+  const waylandDisplay = process.env.WAYLAND_DISPLAY;
+  
+  return sessionType === 'wayland' || !!waylandDisplay;
+}
+
+/**
+ * Checks if running on X11
+ */
+export function isX11(): boolean {
+  const sessionType = process.env.XDG_SESSION_TYPE;
+  const display = process.env.DISPLAY;
+  
+  return sessionType === 'x11' || (!isWayland() && !!display);
+}
